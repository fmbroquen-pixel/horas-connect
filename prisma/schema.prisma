// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  admin
  guest
  reader
}

enum Modalidad {
  presencial
  virtual
  valor_cero
}

// "Ownership" en la UI. Los valores viejos (titular/acompanante) quedan
// mapeados en la base para no migrar datos: el codigo usa owner/backup.
enum Ownership {
  owner      @map("titular")
  backup     @map("acompanante")
  valor_cero

  @@map("RolSesion")
}

enum TipoTarifa {
  fija
  variable
}

enum Moneda {
  USD
  ARS
}

enum ConceptoViatico {
  combustible
  alojamiento
  traslado
  almuerzo
  otros
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String   @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registros     RegistroHoras[]
  asignaciones  ProyectoAsignado[]
  viaticos      Viatico[]
  facturaciones Facturacion[]

  @@map("clientes")
}

// Facturación (lo que se le cobra al cliente) por proyecto y por mes. La
// carga el administrador; el margen del informe de rentabilidad es esta
// facturación menos el costo de mentores (suma de montoUsd de las horas).
model Facturacion {
  id        String   @id @default(cuid())
  clienteId String   @map("cliente_id")
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  anio      Int
  mes       Int // 1-12
  montoUsd  Decimal  @map("monto_usd") @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clienteId, anio, mes])
  @@index([anio, mes])
  @@map("facturaciones")
}

// Texto libre de "lecturas del mes" que redacta el administrador y que ve
// todo el que accede al informe de ese mes.
model NotaMes {
  id        String   @id @default(cuid())
  anio      Int
  mes       Int
  texto     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([anio, mes])
  @@map("notas_mes")
}

// Una sola entidad para todas las personas que usan la app. El "mentor" de
// las conversaciones con el cliente es, en el modelo de datos, un Usuario
// con rol "guest": no hace falta una tabla aparte para lo mismo.
model Usuario {
  id     String     @id @default(cuid())
  email  String     @unique
  nombre String
  rol    RolUsuario @default(guest)
  activo Boolean    @default(true)

  // Solo aplica a usuarios "guest". Definido por el administrador:
  // "fija" = un unico valor USD/hora sin importar modalidad ni ownership.
  // "variable" = un valor por cada combinacion de modalidad x ownership.
  // Nulo = todavia no configurado (no puede cargar horas facturables).
  tipoTarifa TipoTarifa? @map("tipo_tarifa")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tarifas            Tarifa[]
  registros          RegistroHoras[]    @relation("Mentor")
  registrosCreados   RegistroHoras[]    @relation("CreadoPor")
  proyectosAsignados ProyectoAsignado[]
  viaticos           Viatico[]
  vacaciones         Vacacion[]

  @@map("usuarios")
}

// Restringe en que proyectos puede cargar horas un usuario "guest". Un
// usuario sin filas acá (o admin/reader) no tiene esta restricción aplicada
// en el formulario de carga.
model ProyectoAsignado {
  id        String  @id @default(cuid())
  usuarioId String  @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  clienteId String  @map("cliente_id")
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  createdAt DateTime @default(now())

  @@unique([usuarioId, clienteId])
  @@map("proyectos_asignados")
}

// "Etapa" en la UI (antes "Tema/Temática"); la tabla en la base conserva su
// nombre original para no migrar datos.
model Etapa {
  id        String   @id @default(cuid())
  etiqueta  String
  grupo     String
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())

  registros RegistroHoras[]
  viaticos  Viatico[]

  @@map("temas")
}

// Historial de tarifas por usuario (guest). Al cambiar una tarifa se cierra
// la vigente (vigenteHasta) y se crea una fila nueva; los registros ya
// cargados guardan su propio snapshot en RegistroHoras y no se ven
// afectados por este cambio.
model Tarifa {
  id           String    @id @default(cuid())
  usuarioId    String    @map("usuario_id")
  usuario      Usuario   @relation(fields: [usuarioId], references: [id])
  modalidad    Modalidad
  ownership    Ownership @map("rol")
  valorUsd     Decimal   @map("valor_usd") @db.Decimal(10, 2)
  vigenteDesde DateTime  @default(now()) @map("vigente_desde")
  vigenteHasta DateTime? @map("vigente_hasta")
  createdAt    DateTime  @default(now())

  @@unique([usuarioId, modalidad, ownership, vigenteDesde])
  @@index([usuarioId, modalidad, ownership, vigenteHasta])
  @@map("tarifas")
}

model RegistroHoras {
  id        String    @id @default(cuid())
  fecha     DateTime  @db.Date
  clienteId String    @map("cliente_id")
  cliente   Cliente   @relation(fields: [clienteId], references: [id])
  usuarioId String    @map("usuario_id")
  usuario   Usuario   @relation("Mentor", fields: [usuarioId], references: [id])
  etapaId   String?   @map("tema_id")
  etapa     Etapa?    @relation(fields: [etapaId], references: [id])
  horas     Decimal   @db.Decimal(5, 2)
  modalidad Modalidad
  ownership Ownership @map("rol")
  nota      String?

  // Snapshot de la tarifa aplicada al momento de guardar (no se recalcula
  // retroactivamente si la tarifa del usuario cambia despues).
  tarifaUsdAplicada Decimal @map("tarifa_usd_aplicada") @db.Decimal(10, 2)
  montoUsd          Decimal @map("monto_usd") @db.Decimal(10, 2)

  creadoPorId String  @map("creado_por_id")
  creadoPor   Usuario @relation("CreadoPor", fields: [creadoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([usuarioId, fecha])
  @@index([clienteId, fecha])
  @@map("registros_horas")
}

model Viatico {
  id        String          @id @default(cuid())
  fecha     DateTime        @db.Date
  usuarioId String          @map("usuario_id")
  usuario   Usuario         @relation(fields: [usuarioId], references: [id])
  clienteId String          @map("cliente_id")
  cliente   Cliente         @relation(fields: [clienteId], references: [id])
  etapaId   String?         @map("etapa_id")
  etapa     Etapa?          @relation(fields: [etapaId], references: [id])
  moneda    Moneda
  monto     Decimal         @db.Decimal(12, 2)
  concepto  ConceptoViatico
  // Ruta del comprobante en Supabase Storage (bucket privado), opcional.
  archivoPath String?       @map("archivo_path")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([usuarioId, fecha])
  @@index([clienteId, fecha])
  @@map("viaticos")
}

model Vacacion {
  id          String   @id @default(cuid())
  usuarioId   String   @map("usuario_id")
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  fechaInicio DateTime @map("fecha_inicio") @db.Date
  fechaFin    DateTime @map("fecha_fin") @db.Date
  dias        Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([usuarioId, fechaInicio])
  @@map("vacaciones")
}
